# Copia este archivo como .env y ajusta los valores para sobreescribir los defaults.

# Password de root de MySQL (usado por el contenedor de BD y por cada microservicio)
DB_PASSWORD=duocgame2026

# Secreto HMAC para firmar y validar los JWT (debe ser largo, >= 32 caracteres).
# El mismo valor lo usan ms-user (firma) y ms-gateway (validación).
JWT_SECRET=change-this-super-secret-key-for-duoc-rpg-microservices-2026
